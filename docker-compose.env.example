# Copy this file to .env before running docker compose.

# Host repository/project mounted into the containers for cc-haha to answer questions about.
CC_HAHA_HOST_WORKDIR=./workspace

# API key MaxKB sends as Bearer token.
MAXKB_OPENAI_API_KEY=change-me

# Docker runtime: allow env-based model auth instead of managed OAuth.
CC_HAHA_USE_ENV_AUTH=1

# Optional server proxy for outbound model traffic.
# Use the proxy address exposed by your hy2 client, for example:
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7891
# NO_PROXY=127.0.0.1,localhost,::1

# Model provider credentials used by the cc-haha CLI inside Docker.
ANTHROPIC_API_KEY=your_model_api_key_here
ANTHROPIC_AUTH_TOKEN=your_model_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7
API_TIMEOUT_MS=3000000

DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
